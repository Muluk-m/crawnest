{
  "name": "openclaw-desktop",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "download-node": "node scripts/download-node.cjs",
    "download-node:current": "node scripts/download-node.cjs --current-only",
    "prepare-runtime": "node scripts/prepare-runtime.cjs",
    "prepare-plugin": "node scripts/prepare-plugin.cjs",
    "prepare-all": "pnpm download-node && pnpm prepare-runtime && pnpm prepare-plugin",
    "verify-build": "node scripts/verify-build.cjs",
    "package:mac": "pnpm prepare-all && pnpm build && pnpm verify-build && pnpm tauri build",
    "package:win": "pnpm prepare-all && pnpm build && pnpm verify-build && pnpm tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.7",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
