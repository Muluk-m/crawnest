{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Desktop",
  "version": "0.2.5",
  "identifier": "com.openclaw.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw Desktop",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/**/*"
    ],
    "category": "DeveloperTool",
    "shortDescription": "OpenClaw Desktop - AI Gateway Manager",
    "longDescription": "A desktop application for managing OpenClaw AI gateway with built-in Node.js runtime and Feishu integration.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
